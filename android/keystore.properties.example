# Release-Signierung für Google Play.
# 1) Diese Datei nach  android/keystore.properties  kopieren
# 2) echte Werte eintragen   3) NICHT einchecken (steht in .gitignore)
#
# Upload-Keystore einmalig erzeugen (im Ordner android/app/):
#   keytool -genkey -v -keystore fffunk-upload.jks -alias fffunk \
#           -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=fffunk-upload.jks
storePassword=DEIN_STORE_PASSWORT
keyAlias=fffunk
keyPassword=DEIN_KEY_PASSWORT
